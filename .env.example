# ==============================================================================
# Playwright BDD Framework Configuration (Example)
# Copy this file to .env and fill in the values for local execution.
# ==============================================================================

# --- Execution Settings ---
# Browser type: chromium, firefox, or webkit
BROWSER=chromium

# Run in headless mode (true) or see the browser UI (false)
HEADLESS=true

# Launch the browser window maximized (true/false)
MAXIMIZE=false

# Add a delay (ms) between Playwright actions to slow down execution (useful for debugging)
SLOW_MO=500

# Default timeout for all Playwright actions and assertions
DEFAULT_TIMEOUT_MS=60000

# Timeout specifically for individual actions like click, fill, type, etc.
ACTION_TIMEOUT_MS=100000

# Timeout for page navigation (e.g., waiting for a page to load)
NAVIGATION_TIMEOUT_MS=30000

# Number of parallel workers (0 uses the default based on CPU cores)
PARALLEL=0

# Number of times to retry a failed test scenario
RETRY=0

# Filter scenarios by tags (e.g., @smoke, @regression, @login)
TAGS=

# --- URLs ---
# The primary entry point for the application under test
BASE_URL=

# URL for testing basic UI components and controls
BASIC_CONTROLS_URL=

# Specific URL for the main target website
RBGWEBSITE_URL=

# --- Credentials & Verification ---
# Application authentication details
APP_USERNAME=
APP_PASSWORD=

# Enable (true) or disable (false) manual verification steps during test execution
ALLOW_MANUAL_VERIFICATION=false

# Maximum time (ms) to wait for a manual verification step before failing
MANUAL_VERIFICATION_TIMEOUT_MS=120000

# --- Reporting & Debugging ---
# Directory where Allure test results will be stored
ALLURE_RESULTS_DIR=allure-results

# Automatically capture a screenshot when a test scenario fails
SCREENSHOT_ON_FAILURE=true

# Attach screenshots to the report for every test step (even passing ones)
ATTACH_SCREENSHOTS=false

# Record a video of the test execution (true/false)
RECORD_VIDEO=false

# Enable Playwright tracing for deep debugging of test runs
TRACE=false

# Highlight the element being interacted with during the test (useful for visual debugging)
HIGHLIGHT_ELEMENTS=false
