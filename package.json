{
  "name": "playwright-bdd-framework",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "identity": "node -e \"const n=Buffer.from('VGhpcnVtYW5kYXMgU2FpdGVqYSBHb3Vk','base64').toString('utf8');console.log('[Framework Owner] '+n)\"",
    "setup": "node scripts/setup.js",
    "pretest": "npm run identity --silent",
    "pretest:raw": "node src/utils/reporting/reportManager.js --clean",
    "pretest:one": "node src/utils/reporting/reportManager.js --clean",
    "presteps:generate": "",
    "prereport": "",
    "preopen-report": "",
    "pretest:report": "npm run identity",
    "pretest:report:no-open": "npm run identity",
    "precucumber:report": "",
    "precucumber:report:generate": "",
    "precucumber:report:open": "",
    "test:raw": "cucumber-js --config src/config/cucumber.cjs",
    "test": "npm run test:raw",
    "test:one": "node src/utils/dev-tools/testHelpers.js single",
    "test:smoke": "npm run test:raw -- --tags @smoke",
    "test:regression": "npm run test:raw -- --tags @regression",
    "test:wip": "npm run test:raw -- --tags @wip",
    "test:flaky": "cross-env RETRY=3 npm run test:raw -- --tags @flaky",
    "test:api": "npm run test:raw -- --tags @api",
    "test:dry": "node src/utils/dev-tools/testHelpers.js dry",
    "steps:generate": "node src/utils/dev-tools/generator.js",
    "steps:check": "node src/utils/dev-tools/maintenance.js check",
    "report:generate": "allure generate allure-results --clean -o allure-report && npm run report:archive",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run print-report",
    "report:archive": "node src/utils/reporting/reportManager.js --archive",
    "open-report": "npm run report:open",
    "print-report": "node src/utils/reporting/reportManager.js --print",
    "cucumber:report:generate": "node src/utils/reporting/reportManager.js --cucumber",
    "cucumber:report:open": "node src/utils/reporting/reportManager.js --open-cucumber",
    "cucumber:report": "npm run cucumber:report:generate && npm run cucumber:report:open",
    "test:report": "node src/utils/reporting/workflow.js --open",
    "test:report:no-open": "node src/utils/reporting/workflow.js",
    "test:retry-report": "node src/utils/reporting/reportManager.js --cucumber",
    "prereport:history": "npm run identity",
    "report:history": "node src/utils/reporting/reportManager.js --history",
    "report:dashboard": "node src/utils/reporting/reportManager.js --dashboard",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.js\"",
    "imports:check": "node src/utils/dev-tools/maintenance.js import",
    "imports:fix": "node src/utils/dev-tools/maintenance.js import --fix",
    "bdd": "cucumber-js --config src/config/cucumber.cjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@faker-js/faker": "^10.3.0",
    "@types/node": "^25.3.5",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "allure-commandline": "^2.37.0",
    "allure-cucumberjs": "^3.6.0",
    "allure-js-commons": "^3.6.0",
    "chai": "^6.2.2",
    "cross-env": "^10.1.0",
    "cucumber-html-reporter": "^7.2.0",
    "dotenv": "^16.6.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cucumber": "^2.0.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "playwright": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  }
}
